# Скопируйте в файл `.env` рядом с docker-compose.yml для подстановки переменных:
#   cp env.docker.example .env
#
# Docker Compose читает `.env` автоматически.

# PostgreSQL (Prisma). Сервис Postgres в этом compose — имя хоста `db` (не localhost внутри контейнера app).
# Держите в .env / .env.local только ОДНУ строку DATABASE_URL без дубликатов.
DATABASE_URL=postgresql://bsuir:bsuir@db:5432/bsuir?schema=public

# Модуль анализа (антилогия) на другой машине
ANALYSIS_SERVICE_URL=http://172.16.251.219:8765

# Должен совпадать с ANALYSIS_API_KEY в antiplagiarism_worker_pgsql/docker-compose.yml
ANALYSIS_SERVICE_API_KEY=change-me-in-production

# Подпись httpOnly-cookie сессии (админка + /api/admin). Минимум 16 символов; в продакшене задайте свой секрет.
# Если не задано, для разработки используется запасной ключ (не для боевого сервера).
SESSION_SECRET=change-me-long-random-string-for-session-cookies
