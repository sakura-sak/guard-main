# Production БГУИР — для npm run dev / K8s на сервере guard-main
# Скопируйте в .env.local на боевом хосте (или подставьте в ConfigMap).

# ---------------------------------------------------------------------------
# Публичные URL
# ---------------------------------------------------------------------------

NEXT_PUBLIC_APP_URL=https://antiplagiat.bsuir.by
REPORT_PUBLIC_BASE_URL=https://antiplagiat.bsuir.by

# ---------------------------------------------------------------------------
# БД и ML
# ---------------------------------------------------------------------------

DATABASE_URL=postgresql://bsuir:bsuir@db:5432/bsuir?schema=public
ANALYSIS_SERVICE_URL=http://analysis:8765
# ANALYSIS_SERVICE_URL=http://172.16.251.219:8765

# ---------------------------------------------------------------------------
# Секреты — заменить
# ---------------------------------------------------------------------------

SESSION_SECRET=REPLACE-WITH-LONG-RANDOM-SECRET-MIN-16-CHARS
REPORT_ACCESS_SECRET=REPLACE-WITH-STABLE-QR-SECRET-MIN-16-CHARS
CLEANUP_CRON_SECRET=REPLACE-WITH-CRON-SECRET
ANALYSIS_SERVICE_API_KEY=REPLACE-WITH-ML-API-KEY

# ---------------------------------------------------------------------------
# LDAP БГУИР
# ---------------------------------------------------------------------------

LDAP_ENABLED=true
LDAP_URL=ldaps://ldap.bsuir.by
LDAP_BASE_DN=dc=bsuir,dc=by
LDAP_BIND_DN=uid=smdoadmin,ou=staff,dc=bsuir,dc=by
LDAP_BIND_PASSWORD=REPLACE-WITH-LDAP-BIND-PASSWORD
LDAP_USER_SEARCH_BASES=ou=staff,dc=bsuir,dc=by;ou=stud,dc=bsuir,dc=by
LDAP_USER_SEARCH_FILTER=(uid={username})
LDAP_USERNAME_ATTRIBUTE=uid
LDAP_EMAIL_ATTRIBUTE=mail
LDAP_FIRSTNAME_ATTRIBUTE=givenName
LDAP_LASTNAME_ATTRIBUTE=sn
LDAP_MIDDLENAME_ATTRIBUTE=middleName
LDAP_TIMEOUT=10000

ARCHIVE_PURGE_ENABLED=true
ARCHIVE_PURGE_HOUR=3
ARCHIVE_PURGE_MINUTE=0
